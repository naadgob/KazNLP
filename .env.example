# Hugging Face (model downloads)
HF_TOKEN=

# Telegram collection (notebooks/telethon_learning.ipynb)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: YouTube API
YOUTUBE_API_KEY=

# Language labeler — default: local Ollama (free, no limits)
LABELER_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_NUM_CTX=8192
LABELER_QUALITY=high
OLLAMA_BATCH_SIZE=50
APPLY_PRECISION_FILTER=true

# fast | balanced | high | max — few-shot + verify mixed (high/max)
# OLLAMA_BATCH_SIZE overrides preset batch when set

# Optional: cloud Gemini (set LABELER_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Manual labeler: MyMemory translate hint (free ~1000 words/day; +10k with email)
MYMEMORY_EMAIL=
